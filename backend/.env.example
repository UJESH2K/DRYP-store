# --- DRYP Backend Environment ---
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# MongoDB connection string. Local: mongodb://127.0.0.1:27017/dryp
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/dryp?retryWrites=true&w=majority
MONGO_URI=

# JWT secret used to sign auth tokens. Use a long random string in production.
# You can generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Port the API listens on. Defaults to 8080 if unset.
# Production on AWS should set this to 8080 (matches Dockerfile).
PORT=8080

# Public URL of the Next.js website (used to build password-reset and
# vendor-approval links in emails). Local: http://localhost:3000
# Production: https://your-vercel-domain.vercel.app
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# --- SMTP (used by src/utils/sendEmail.js for password resets, vendor
# approvals, and suspension notices). Any SMTP provider works (SendGrid,
# Mailgun, AWS SES, Resend, Gmail app-passwords in dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_EMAIL=
SMTP_PASSWORD=

# "From" header shown on outbound emails.
FROM_NAME=DRYP
FROM_EMAIL=no-reply@dryp.com

# --- Payments ---
# Razorpay (used by routes/payments.js). Get test keys from
# https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
