# --- DRYP Frontend (Expo) Environment ---
# Copy this file to `.env`. Expo reads any var prefixed with EXPO_PUBLIC_ at
# build time. Never commit `.env`.

# Base URL of the DRYP backend. Two cases:
#   - Real device on the same Wi-Fi as your dev machine:
#     http://<your-laptop-LAN-IP>:8080  (find with `ipconfig getifaddr en0` on macOS)
#   - Deployed backend (production / TestFlight builds):
#     https://api.your-domain.com
# NEVER use `localhost` — phones can't reach it.
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.9:8080
