{
  "expo": {
    "name": "DRYP",
    "slug": "dryp",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "dryp",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dryp.store",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "DRYP needs access to your photos so you can share style inspiration and save your favorite looks.",
        "NSCameraUsageDescription": "DRYP uses the camera to let you capture outfit photos and discover similar styles.",
        "NSPhotoLibraryAddUsageDescription": "DRYP can save outfit photos and screenshots to your photo library.",
        "NSMicrophoneUsageDescription": "DRYP may use the microphone for video-based style recommendations in the future.",
        "NSPrivacyPolicyURL": "https://www.dryp.store/legal/privacy"
      }
    },
    "android": {
      "backgroundColor": "#000000",
      "package": "com.dryp.store",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      }
    },
    "plugins": [
      "expo-font",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "536cd845-448b-48b5-a5a9-c7386ec35dde"
      }
    },
    "owner": "dryps-team"
  }
}
